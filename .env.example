# ─── Сейчастье — пример конфигурации ───────────────────────────
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# Обязательно сгенерируйте уникальный ключ:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замените_на_случайную_строку_минимум_32_символа

# Порт сервера (по умолчанию 5000)
PORT=5000

# Время жизни JWT-сессии в минутах (по умолчанию 60)
JWT_EXPIRE_MIN=60

# ─── Telegram-уведомления о заказах ─────────────────────────────
# Создайте бота через @BotFather, получите токен
# Найдите chat_id через @userinfobot или API getUpdates
TG_BOT_TOKEN=1234567890:AABBccDDeeff...
TG_CHAT_ID=123456789
